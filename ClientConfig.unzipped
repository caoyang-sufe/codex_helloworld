	"Item":[
		{ "Tip": "每天可以免费开启1次锦囊袋，不要错过哦~", "ViewType": 1 },
		{ "Tip": "建议下载微端、使用谷歌浏览器登录游戏", "ViewType": 1 },
		{ "Tip": "点击大厅的三国秀可以查看个人信息", "ViewType": 1 },
		{ "Tip": "每次武将招募必定会获得1名新武将", "ViewType": 1 },
		{ "Tip": "开启皮肤包获得传说限定皮肤时会有全屏大图的展示", "ViewType": 1 },
		{ "Tip": "传统身份、国战模式的竞技场对决更能展现你的对局水平", "ViewType": 1 },
		{ "Tip": "打开声音，在不同模式场景中可以欣赏不同的背景音乐", "ViewType": 1 },
		{ "Tip": "请在信件过期前及时领取附件道具啊~", "ViewType": 2 },
		{ "Tip": "发送信件的内容最多为300字哦~", "ViewType": 2 },
		{ "Tip": "信件最多保留10天，逾期系统会狠心自动删除的~", "ViewType": 2 },
		{ "Tip": "请及时查看未读信件，别错过重要的消息哦~", "ViewType": 2 },
		{ "Tip": "每个页签下的连胜单独计算，互不影响哦~", "ViewType": 3 },
		{ "Tip": "全部页签下会显示各个模式的牌局信息", "ViewType": 3 },
		{ "Tip": "右上角的“返回”按钮可以回到个人信息界面~", "ViewType": 3 },
		{ "Tip": "你可以上场的武将越多，刷新出高级武将的概率越大", "ViewType": 4 },
		{ "Tip": "积攒铜钱可以获得利息，当心都刷新掉了", "ViewType": 4 },
		{ "Tip": "你遣散掉的武将，可能会出现在别人的招募中", "ViewType": 4 },
		{ "Tip": "战斗过程中你也可以进行招募和遣散", "ViewType": 4 },
		{ "Tip": "刷新一时爽，一直刷新一直爽", "ViewType": 4 },
		{ "Tip": "每个轮开始时招募会自动刷新一次", "ViewType": 4 },
		{ "Tip": "如果你锁定了招募，招募就不会自动刷新了", "ViewType": 4 },
		{ "Tip": "红色是传说级的武将，出现概率也最低", "ViewType": 4 },
		{ "Tip": "稀有度越高的武将价格越高", "ViewType": 4 },
		{ "Tip": "相同的武将在手牌或者场上会自动合成", "ViewType": 4 },
		{ "Tip": "三星是最高级的武将，也最厉害", "ViewType": 4 },
		{ "Tip": "关注其他人的武将阵容，调整自己的策略", "ViewType": 4 },
		{ "Tip": "连胜或者连败也可以获得额外铜钱", "ViewType": 4 },
		{ "Tip": "记得立志，赢得更多", "ViewType": 4 },
		{ "Tip": "有的时候也许需要放手一刷", "ViewType": 4 },
		{ "Tip": "所有人是共享一个武将牌库的", "ViewType": 4 },
		{ "Tip": "试着尝试一下不同的阵容和协战效果吧", "ViewType": 4 },
		{ "Tip": "协战效果很强力，千万不要忽视", "ViewType": 4 },
		{ "Tip": "每个武将携带的卡牌是不一样的", "ViewType": 4 },
		{ "Tip": "没有卡牌的武将在回合开始的时候会掉血摸牌", "ViewType": 4 },
		{ "Tip": "50铜钱以上就不会再有额外利息了，刷吧", "ViewType": 4 },
		{ "Tip": "武将的站位决定先手顺序", "ViewType": 4 },
		{ "Tip": "武将的技能发动大部分是有概率的", "ViewType": 4 },
		{ "Tip": "有些武将在前期比较厉害，有的则反过来", "ViewType": 4 },
		{ "Tip": "超过上场人数限制的武将在每轮开始时会下场", "ViewType": 4 },
		{ "Tip": "备战区最多保留8张武将牌", "ViewType": 4 },
		{ "Tip": "这里不止有三个势力的武将", "ViewType": 4 },
		{ "Tip": "有的势力武将数量比较少", "ViewType": 4 },
		{ "Tip": "有的武将只有一个也可以触发协战效果", "ViewType": 4 },
		{ "Tip": "武将升级后携带的卡牌数量也会更多", "ViewType": 4 },
		{ "Tip": "你可以在图鉴里找到所有武将和卡牌的介绍", "ViewType": 4 },
		{ "Tip": "玩几局自走棋，再来几局欢乐成双也是极好的", "ViewType": 4 },
		{ "Tip": "所有人都组相同势力，那么大家都很难组成", "ViewType": 4 },
		{ "Tip": "武将会优先攻击正对面的敌方武将", "ViewType": 4 },
		{ "Tip": "杀的伤害=武将的星级", "ViewType": 4 },
		{ "Tip": "将灵的牌局技能仅在武将列传、公会争霸战、逐鹿天下中生效", "ViewType": 5 },
		{ "Tip": "永久激活会员的玩家才可以领取红包", "ViewType": 6 },
		{ "Tip": "公会成员每日可领取红包的上限为30个", "ViewType": 6 },
		{ "Tip": "进入公会24小时之后才可领取红包", "ViewType": 6 },
		{ "Tip": "圈子动态的刷新存在些许延迟，可以点击右侧按钮主动刷新", "ViewType": 6 },
		{ "Tip": "只要完成互动任务就可获得骰子！", "ViewType": 7 },
		{ "Tip": "秘境探索是限时活动，请在活动周期内尽快使用完骰子！", "ViewType": 7 }
	], 
